    "@types/node": "^24.5.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
